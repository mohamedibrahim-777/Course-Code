# Database Configuration
# The app uses SQLite (database.db) which is created automatically.

# JWT Secret for session management
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_me_with_a_64_byte_random_hex_string"

# Comma-separated allowed CORS origins (e.g. https://yourdomain.com,https://www.yourdomain.com)
# In dev, use http://localhost:3000
CORS_ORIGINS="http://localhost:3000"

# Server port
PORT=3000

# Admin Emails (Predefined)
HOD_EMAIL="hod@example.com"
STAFF1_EMAIL="staff1@example.com"
STAFF2_EMAIL="staff2@example.com"

# Seed password for predefined HOD/staff accounts (only used on first DB init)
SEED_PASSWORD="change-me-on-first-deploy"

# Supabase Postgres database (Settings → Database → Connection string → URI)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Supabase project (Settings → API → Project URL + service_role key)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_KEY=""
SUPABASE_BUCKET="uploads"

# Gemini API Key (Injected by AI Studio)
GEMINI_API_KEY=""
APP_URL=""
